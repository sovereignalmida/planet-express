venv/
__pycache__/
*.pyc

# Runtime state and logs are host-specific, not part of the shipped project
state/*.json
logs/*.log

# Real topology config is host-specific (real stack names, mounts) — never commit it.
# Shipped default location is /etc/planetexpress/config.yaml (outside the repo entirely);
# this host overrides via CASA_CONFIG to keep it under the app directory instead, so it
# needs an explicit ignore here. config.example.yaml (generic placeholders) stays tracked.
/config.yaml

# Never commit secrets — production config lives in /etc/planetexpress.env
.env
*.env

# Design reference/handoff material for dashboard redo — not shipped code
/design-handoff/
